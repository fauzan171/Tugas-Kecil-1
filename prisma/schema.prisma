// prisma/schema.prisma
// Tugas Kecil 1 — Student API (Bonus Prisma)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id        Int      @id @default(autoincrement())
  name      String
  nim       String   @unique
  major     String
  gpa       Float    @default(0)
  createdAt DateTime @default(now())
}
